# sample surface deposition script for atoms
# part 1 start, build the world and put atom at the bottom
units		lj
atom_style      atomic # each atom has only position, velocity, force, atom type
boundary        p p f # height is fixed

lattice		fcc 1.0 # we only use this crystal
region          box block 0 5 0 5 0 10
create_box      2 box # with 2 types of atoms, surface atoms and deposited atoms.

region		substrate block INF INF INF INF INF 3
create_atoms	1 region substrate # so the substrate has only 1 type of atom
####################part 1 end##################
######################################################################
######################################################################
######################################################################



#start part 2, atoms interact with eachother (define physics)
pair_style	lj/cut 2.5
pair_coeff	* * 1.0 1.0
pair_coeff	1 2 1.0 1.0 5.0 # by this the atoms can feel surface from further away.
mass		* 1.0 # * mean all
####################part 2 end##################
######################################################################
######################################################################
######################################################################



#start part 3, group atoms, LAMMPS needs different groups.

neigh_modify	delay 0 # never delay rebuilding the neighbor list.

group		addatoms type 2 # type 2 is incoming atoms
region          mobile block 0 5 0 5 2 INF
group		mobile region mobile # create group named mobile, that atoms inside it belongs to region mobile

compute		add addatoms temp # only incoming atoms
compute_modify	add dynamic/dof yes extra/dof 0 

####################part 3 end##################
######################################################################
######################################################################
######################################################################


# start part 4, start moving the atoms according to Newton's laws.

fix		1 addatoms nve # move atoms according to Newton's laws while energy is constant.
fix		2 mobile langevin 1.0 1.0 0.1 587283 # control temperature, langevin is a thermostat
fix		3 mobile nve # insert atoms
####################part 4 end##################
######################################################################
######################################################################
######################################################################



# start part 5, create new atoms and update

region          slab block 0 5 0 5 8 9
fix		4 addatoms deposit 100 2 100 12345 region slab near 1.0 &
                vz -1.0 -1.0 # Insert 100 new atoms of type 2 into the slab region, one every 100 timesteps, at random positions that are at least 1.0 distance from existing atoms, with the downward velocity
fix		5 addatoms wall/reflect zhi EDGE #Create a reflecting wall at the upper (high-z) edge of the simulation box so that deposited atoms bounce back instead of escaping the simulation.
####################part 5 end##################
######################################################################
######################################################################
######################################################################



thermo_style	custom step atoms temp epair etotal press
thermo          100
thermo_modify	temp add

dump		1 all atom 50 dump.deposit.atom

dump		2 all image 1000 image.*.jpg type type &
#		axes yes 0.8 0.02 view 80 -30
#dump_modify	2 pad 5

#dump		3 all movie 50 movie.mpg type type &
#		axes yes 0.8 0.02 view 80 -30
#dump_modify	3 pad 5

run             10000
